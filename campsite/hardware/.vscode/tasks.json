{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "PlatformIO Upload",
			"type": "shell",
			"command": "~/.platformio/penv/Scripts/platformio.exe run --target upload",
			"problemMatcher": [
				"$platformio"
			],
			"group": "build"
		},
		{
			"label": "PlatformIO Upload and Monitor",
			"type": "shell",
			"command": "~/.platformio/penv/Scripts/platformio.exe run --target upload --target monitor",
			"problemMatcher": [
				"$platformio"
			],
			"group": "build"
		},
		{
			"label": "PlatformIO Monitor",
			"type": "shell",
			"command": "~/.platformio/penv/Scripts/platformio.exe device monitor",
			"isBackground": true,
			"problemMatcher": [
				"$platformio"
			],
			"group": "test"
		},
		{
			"label": "Upload ESP32",
			"type": "shell",
			"command": "~/.platformio/penv/Scripts/platformio.exe run --target upload",
			"problemMatcher": [
				"$platformio"
			],
			"group": "build"
		},
		{
			"label": "Upload and Monitor",
			"type": "shell",
			"command": "~/.platformio/penv/Scripts/platformio.exe run --target upload --target monitor",
			"problemMatcher": [
				"$platformio"
			],
			"group": "build"
		},
		{
			"label": "Upload Fixed",
			"type": "shell",
			"command": "~/.platformio/penv/Scripts/platformio.exe run --target upload",
			"problemMatcher": [
				"$platformio"
			],
			"group": "build"
		}
	]
}